---
import PageLayout from '../layouts/PageLayout.astro';
import PlatformIcons from '../components/PlatformIcons.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('en');
---

<PageLayout
  title="Contact — Luxury London Weddings"
  description="Get in touch with Luxury London Weddings. We respond to all enquiries within 24 hours."
>
  <section class="pt-32 pb-24 bg-warm-black">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-ivory mb-6">
        {t('contact.headline')}
      </h1>
      <div class="flex justify-center mt-8">
        <div class="w-12 h-px bg-gold/30"></div>
      </div>
    </div>
  </section>

  <section class="py-28 bg-ivory">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <p class="text-slate text-base font-light leading-relaxed mb-16 max-w-lg mx-auto italic">
        {t('contact.footer')}
      </p>

      <div class="grid md:grid-cols-2 gap-16">
        <!-- Email -->
        <div>
          <h3 class="font-serif text-2xl text-dark mb-3 font-light">{t('contact.email')}</h3>
          <a href="mailto:hello@luxurylondonweddings.co.uk" class="text-gold hover:text-gold-light text-sm font-light transition-colors duration-300 tracking-wide">
            hello@luxurylondonweddings.co.uk
          </a>
        </div>

        <!-- WeChat -->
        <div>
          <h3 class="font-serif text-2xl text-dark mb-3 font-light">{t('contact.wechat')}</h3>
          <p class="text-slate text-sm font-light tracking-wide">LuxuryLondonWeddings</p>
        </div>
      </div>

      <div class="flex justify-center my-16">
        <div class="w-8 h-px bg-gold/20"></div>
      </div>

      <PlatformIcons />
    </div>
  </section>
</PageLayout>
