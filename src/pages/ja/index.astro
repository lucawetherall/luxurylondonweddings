---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import StatsBar from '../../components/StatsBar.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import VenueMarquee from '../../components/VenueMarquee.astro';
import WhyUs from '../../components/WhyUs.astro';
import GuaranteeBadge from '../../components/GuaranteeBadge.astro';
import AgentCTA from '../../components/AgentCTA.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('ja');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Luxury London Weddings',
  description: 'ロンドンの教会、チャペル、歴史的な邸宅での前撮り撮影・祝福式・ウェディングフォトの会場手配。',
  url: 'https://luxurylondonweddings.co.uk/ja/',
  email: 'hello@luxurylondonweddings.co.uk',
  areaServed: ['London', 'England', 'Scotland', 'United Kingdom'],
  serviceType: 'Wedding Venue Brokerage',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'London',
    addressCountry: 'GB',
  },
};

const services = [
  { title: t('services.church.title'), description: t('services.church.desc') },
  { title: t('services.blessing.title'), description: t('services.blessing.desc') },
  { title: t('services.estate.title'), description: t('services.estate.desc') },
  { title: t('services.multiVenue.title'), description: t('services.multiVenue.desc') },
  { title: t('services.choir.title'), description: t('services.choir.desc') },
  { title: t('services.agent.title'), description: t('services.agent.desc') },
];
---

<PageLayout
  title="Luxury London Weddings — 英国の教会・歴史的建造物の会場手配"
  description="ロンドンの教会、チャペル、歴史的な邸宅での前撮り撮影・祝福式・ウェディングフォトの会場手配を承ります。"
  lang="ja"
  jsonLd={jsonLd}
>
  <Hero />
  <StatsBar />

  <section class="py-28 lg:py-36 bg-ivory">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="mb-16">
        <p class="text-gold tracking-[0.2em] uppercase text-sm font-light mb-4">
          {t('services.label')}
        </p>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-dark max-w-lg">
          {t('services.title')}
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s, i) => (
          <ServiceCard title={s.title} description={s.description} index={i} />
        ))}
      </div>
    </div>
  </section>

  <VenueMarquee />
  <WhyUs />

  <div class="py-16 bg-ivory">
    <GuaranteeBadge />
  </div>

  <AgentCTA />
</PageLayout>
