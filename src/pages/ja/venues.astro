---
import PageLayout from '../../layouts/PageLayout.astro';
import VenueCard from '../../components/VenueCard.astro';
import { useTranslations } from '../../i18n/utils';
import { getCollection } from 'astro:content';

const t = useTranslations('ja');
const allVenues = await getCollection('venues', ({ data }) => data.locale === 'ja');
---

<PageLayout
  title="厳選会場 — Luxury London Weddings"
  description="イングランドとスコットランドの教会、チャペル、大聖堂、歴史的邸宅。"
  lang="ja"
>
  <section class="pt-32 pb-24 bg-warm-black">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-ivory mb-6">
        {t('venues.headline')}
      </h1>
      <p class="text-champagne/70 text-lg font-light max-w-2xl mx-auto">
        {t('venues.subtitle')}
      </p>
      <div class="flex justify-center mt-8"><div class="w-12 h-px bg-gold/30"></div></div>
    </div>
  </section>

  <section class="py-24 bg-ivory">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {allVenues.map(venue => (
          <VenueCard
            name={venue.data.name}
            location={venue.data.location}
            type={venue.data.type}
            priceRange={venue.data.priceRange}
            exclusive={venue.data.exclusive}
            description={venue.body ?? ''}
            slug={venue.data.slug}
            founded={venue.data.founded}
          />
        ))}
      </div>
    </div>
  </section>
</PageLayout>
