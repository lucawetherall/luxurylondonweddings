---
import PageLayout from '../../layouts/PageLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('zh');
const bodyParagraphs = t('about.body').split('\n\n');
---

<PageLayout
  title="关于我们 — Luxury London Weddings"
  description="Luxury London Weddings 的创立源于一个明确的需求：为海外婚礼策划师提供英国教堂与古典场地预订渠道。"
  lang="zh"
>
  <section class="pt-32 pb-24 bg-warm-black">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-ivory">
        {t('about.headline')}
      </h1>
    </div>
  </section>

  <section class="py-24 bg-ivory">
    <div class="max-w-3xl mx-auto px-6">
      <div class="space-y-6">
        {bodyParagraphs.map(p => (
          <p class="text-slate text-lg font-light leading-relaxed">{p}</p>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
