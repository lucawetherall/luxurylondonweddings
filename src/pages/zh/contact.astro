---
import PageLayout from '../../layouts/PageLayout.astro';
import PlatformIcons from '../../components/PlatformIcons.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('zh');
---

<PageLayout
  title="联系我们 — Luxury London Weddings"
  description="联系Luxury London Weddings。所有咨询24小时内回复。"
  lang="zh"
>
  <section class="pt-32 pb-24 bg-warm-black">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-ivory mb-6">
        {t('contact.headline')}
      </h1>
    </div>
  </section>

  <section class="py-24 bg-ivory">
    <div class="max-w-3xl mx-auto px-6">
      <!-- WeChat primary for zh -->
      <div class="grid md:grid-cols-2 gap-12">
        <div class="text-center">
          <div class="w-16 h-16 border border-gold/20 flex items-center justify-center mx-auto mb-6">
            <span class="text-gold text-2xl">💬</span>
          </div>
          <h3 class="font-serif text-xl text-dark mb-4">微信</h3>
          <div class="w-40 h-40 bg-mist border border-gold/10 flex items-center justify-center mx-auto">
            <span class="text-slate/40 text-xs">WeChat QR Code</span>
          </div>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 border border-gold/20 flex items-center justify-center mx-auto mb-6">
            <span class="text-gold text-2xl">✉</span>
          </div>
          <h3 class="font-serif text-xl text-dark mb-2">{t('contact.email')}</h3>
          <a href="mailto:hello@luxurylondonweddings.co.uk" class="text-gold hover:text-gold-light text-sm font-light transition-colors">
            hello@luxurylondonweddings.co.uk
          </a>
        </div>
      </div>

      <div class="mt-16 text-center">
        <PlatformIcons />
      </div>

      <div class="mt-16 text-center">
        <p class="text-slate text-sm font-light italic">{t('contact.footer')}</p>
      </div>
    </div>
  </section>
</PageLayout>
