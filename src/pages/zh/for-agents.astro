---
import PageLayout from '../../layouts/PageLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('zh');
const bodyParagraphs = t('forAgents.body').split('\n\n');
---

<PageLayout
  title="合作伙伴 — Luxury London Weddings"
  description="专为旅拍工作室和婚礼策划公司打造。优先预约、批量优惠、专属联络通道。"
  lang="zh"
>
  <section class="pt-32 pb-24 bg-warm-black">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-gold tracking-[0.2em] uppercase text-sm font-light mb-6">
        {t('agentCta.label')}
      </p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-ivory">
        {t('forAgents.headline')}
      </h1>
    </div>
  </section>

  <section class="py-24 bg-ivory">
    <div class="max-w-3xl mx-auto px-6">
      <div class="space-y-6">
        {bodyParagraphs.map(p => (
          <p class="text-slate text-lg font-light leading-relaxed">{p}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- WeChat QR prominent -->
  <section class="py-24 bg-mist">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-serif text-3xl font-light text-dark mb-8">开始合作</h2>
      <div class="flex flex-col items-center gap-8">
        <div class="bg-ivory border border-gold/20 p-8">
          <p class="text-gold text-sm tracking-wider uppercase mb-4">微信联系</p>
          <div class="w-40 h-40 bg-mist border border-gold/10 flex items-center justify-center">
            <span class="text-slate/40 text-xs">WeChat QR Code</span>
          </div>
        </div>
        <a href="mailto:hello@luxurylondonweddings.co.uk" class="inline-block px-8 py-4 border border-gold/40 text-gold font-light text-sm tracking-wider uppercase hover:border-gold hover:bg-gold/5 transition-all">
          发送邮件咨询
        </a>
      </div>
    </div>
  </section>
</PageLayout>
