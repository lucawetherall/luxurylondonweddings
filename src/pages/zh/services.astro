---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('zh');

const services = [
  { title: t('services.church.title'), description: t('services.church.desc'), price: t('servicesPage.church.price') },
  { title: t('services.blessing.title'), description: t('services.blessing.desc'), price: t('servicesPage.blessing.price') },
  { title: t('services.estate.title'), description: t('services.estate.desc'), price: t('servicesPage.estate.price') },
  { title: t('services.multiVenue.title'), description: t('services.multiVenue.desc'), price: t('servicesPage.multiVenue.price') },
  { title: t('services.choir.title'), description: t('services.choir.desc'), price: t('servicesPage.choir.price') },
  { title: t('services.agent.title'), description: t('services.agent.desc'), price: t('servicesPage.agentRetainer.price') },
];
---

<PageLayout
  title="服务与价格 — Luxury London Weddings"
  description="教堂摄影、祝福仪式、古堡庄园拍摄、多场地一日行程、现场合唱、代理商合作。透明报价。"
  lang="zh"
>
  <section class="pt-32 pb-24 bg-warm-black">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-ivory mb-6">
        {t('servicesPage.headline')}
      </h1>
      <p class="text-champagne/70 text-lg font-light max-w-2xl mx-auto leading-relaxed">
        {t('servicesPage.intro')}
      </p>
      <div class="flex justify-center mt-8"><div class="w-12 h-px bg-gold/30"></div></div>
    </div>
  </section>

  <section class="py-24 bg-ivory">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s, i) => (
          <ServiceCard title={s.title} description={s.description} index={i} price={s.price} />
        ))}
      </div>
    </div>
  </section>

  <ProcessSteps />
</PageLayout>
