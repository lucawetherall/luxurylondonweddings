---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="max-w-xl mx-auto text-center px-6">
  <div class="flex items-center justify-center gap-4 mb-5">
    <div class="w-10 h-px bg-gold/20"></div>
    <div class="w-1.5 h-1.5 rotate-45 border border-gold/30"></div>
    <div class="w-10 h-px bg-gold/20"></div>
  </div>
  <p class="text-slate/70 text-sm font-light italic leading-relaxed max-w-md mx-auto">
    {t('guarantee')}
  </p>
</div>
