---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

type Platform = {
  name: string;
};

const platformsByLocale: Record<string, Platform[]> = {
  en: [
    { name: 'Instagram' },
    { name: 'Pinterest' },
    { name: 'LinkedIn' },
  ],
  zh: [
    { name: '小红书' },
    { name: '抖音' },
    { name: '微信' },
    { name: 'Instagram' },
  ],
  ja: [
    { name: 'Instagram' },
    { name: 'LINE' },
    { name: 'X/Twitter' },
  ],
};

const platforms = platformsByLocale[lang] ?? platformsByLocale.en;
---

<div class="flex items-center justify-center gap-6 flex-wrap">
  {platforms.map((p) => (
    <span class="text-gold/50 hover:text-gold text-xs font-light tracking-[0.15em] uppercase transition-colors duration-200 cursor-pointer">
      {p.name}
    </span>
  ))}
</div>
