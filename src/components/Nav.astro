---
import { getLangFromUrl, useTranslations, useTranslatedPath, getLocalizedUrl } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);

const navItems = [
  { label: t('nav.venues'), href: tp('/venues/') },
  { label: t('nav.services'), href: tp('/services/') },
  { label: t('nav.forAgents'), href: tp('/for-agents/') },
  { label: t('nav.about'), href: tp('/about/') },
  { label: t('nav.contact'), href: tp('/contact/') },
];
---

<nav data-nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href={tp('/')} class="flex items-center gap-3 group">
        <span class="font-serif text-xl lg:text-2xl font-semibold text-ivory tracking-wide group-hover:text-gold transition-colors duration-300">
          Luxury London Weddings
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-8">
        {navItems.map(item => (
          <a
            href={item.href}
            class="text-champagne/80 hover:text-gold text-sm font-light tracking-wider uppercase transition-colors duration-200"
          >
            {item.label}
          </a>
        ))}
        <div class="w-px h-4 bg-gold/20"></div>
        <LanguageSwitcher />
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden text-ivory p-2 hover:text-gold transition-colors"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-warm-black/95 backdrop-blur-md border-t border-gold/10">
    <div class="px-6 py-8 space-y-5">
      {navItems.map(item => (
        <a
          href={item.href}
          class="block text-champagne/80 hover:text-gold text-base font-light tracking-wider uppercase transition-colors"
        >
          {item.label}
        </a>
      ))}
      <div class="pt-5 border-t border-gold/10">
        <LanguageSwitcher />
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>
