---
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  name: string;
  location: string;
  type: string;
  priceRange: string;
  exclusive?: boolean;
  description: string;
  slug: string;
  founded?: string;
}

const { name, location, type, priceRange, exclusive, description, slug, founded } = Astro.props;
const lang = getLangFromUrl(Astro.url);

const priceLabels: Record<string, Record<string, string>> = {
  en: { standard: '£', premium: '££', luxury: '£££' },
  zh: { standard: '¥', premium: '¥¥', luxury: '¥¥¥' },
  ja: { standard: '¥', premium: '¥¥', luxury: '¥¥¥' },
};

const typeLabels: Record<string, Record<string, string>> = {
  en: { church: 'Church', chapel: 'Chapel', cathedral: 'Cathedral', estate: 'Estate', castle: 'Castle' },
  zh: { church: '教堂', chapel: '礼拜堂', cathedral: '大教堂', estate: '庄园', castle: '城堡' },
  ja: { church: '教会', chapel: 'チャペル', cathedral: '大聖堂', estate: '邸宅', castle: '城' },
};

const exclusiveLabels: Record<string, string> = {
  en: 'Exclusive',
  zh: '独家',
  ja: '独占',
};

const viewLabels: Record<string, string> = {
  en: 'View',
  zh: '查看',
  ja: '詳細',
};

const currentPriceLabels = priceLabels[lang] ?? priceLabels.en;
const currentTypeLabels = typeLabels[lang] ?? typeLabels.en;

// Truncate description to ~120 chars
const shortDesc = description.length > 120 ? description.slice(0, 117).replace(/\s+\S*$/, '') + '...' : description;
---

<article class="group border border-gold/15 hover:border-gold/50 transition-all duration-300 bg-ivory p-7 flex flex-col justify-between min-h-[280px]">
  <div>
    <div class="flex items-start justify-between mb-5">
      <div class="flex items-center gap-3">
        <span class="text-gold text-[10px] tracking-[0.2em] uppercase font-light">{currentTypeLabels[type] ?? type}</span>
        {exclusive && (
          <span class="text-[10px] tracking-[0.15em] uppercase font-light text-gold/60 border border-gold/20 px-1.5 py-0.5">
            {exclusiveLabels[lang] ?? exclusiveLabels.en}
          </span>
        )}
      </div>
      {founded && (
        <span class="text-gold/40 text-[10px] tracking-[0.15em] uppercase font-light">Est. {founded}</span>
      )}
    </div>
    <h3 class="font-serif text-2xl lg:text-[1.65rem] font-light text-dark leading-tight mb-3">{name}</h3>
    <p class="text-slate text-sm font-light leading-relaxed">{shortDesc}</p>
  </div>

  <div class="flex items-center justify-between mt-5 pt-4 border-t border-gold/10">
    <span class="text-champagne text-[11px] tracking-wide font-light">{location}</span>
    <div class="flex items-center gap-3">
      <span class="text-gold/50 text-xs font-light">{currentPriceLabels[priceRange] ?? priceRange}</span>
      <span class="text-gold text-[11px] tracking-[0.15em] uppercase font-light group-hover:tracking-[0.2em] transition-all duration-300">{viewLabels[lang] ?? 'View'} →</span>
    </div>
  </div>
</article>
