---
interface Props {
  title: string;
  description: string;
  index?: number;
  price?: string;
}

const { title, description, index = 0, price } = Astro.props;

const romanNumerals = ['i', 'ii', 'iii', 'iv', 'v', 'vi', 'vii', 'viii'];
const numeral = romanNumerals[index] ?? String(index + 1);
---

<div class="service-card bg-ivory p-8 lg:p-10 group transition-all duration-300 relative">
  <div class="absolute top-8 right-8 lg:top-10 lg:right-10 font-serif text-xl text-gold/40 italic font-light">{numeral}</div>
  <h3 class="font-serif text-xl lg:text-2xl font-normal text-dark mb-4 pr-8">
    {title}
  </h3>
  <p class="text-slate text-sm font-light leading-relaxed">
    {description}
  </p>
  {price && (
    <p class="mt-6 text-gold font-medium text-xs tracking-wider uppercase">
      {price}
    </p>
  )}
  <div class="mt-6 w-8 h-px bg-gold"></div>
</div>
