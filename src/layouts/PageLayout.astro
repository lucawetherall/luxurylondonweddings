---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  lang?: Lang;
  jsonLd?: Record<string, unknown>;
}

const { title, description, lang, jsonLd } = Astro.props;
---

<BaseLayout title={title} description={description} lang={lang} jsonLd={jsonLd}>
  <Nav />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</BaseLayout>
